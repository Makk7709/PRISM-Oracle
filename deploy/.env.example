# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                  KOREV EVIDENCE — Configuration Production                   ║
# ║                                                                              ║
# ║  1. Copier ce fichier :  cp .env.example .env                               ║
# ║  2. Remplir les valeurs marquées XXXXX                                       ║
# ║  3. Lancer :  docker compose up -d                                           ║
# ║                                                                              ║
# ║  ⚠️  NE JAMAIS COMMITER .env avec des secrets !                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════════
# CLÉS API — OBLIGATOIRE (au moins UNE)
# ═══════════════════════════════════════════════════════════════════════════════

# OpenRouter (RECOMMANDÉ — accès multi-modèles : Claude, GPT-4, Gemini, etc.)
# Obtenir une clé : https://openrouter.ai/keys
API_KEY_OPENROUTER=XXXXX

# OpenAI (alternative ou complémentaire)
# Obtenir une clé : https://platform.openai.com/api-keys
API_KEY_OPENAI=

# Anthropic (si accès direct à Claude)
API_KEY_ANTHROPIC=

# Google (si accès direct à Gemini)
API_KEY_GOOGLE=

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTIFICATION — OBLIGATOIRE EN PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════════

# Login et mot de passe (2 variables séparées)
AUTH_LOGIN=admin
AUTH_PASSWORD=XXXXX_MOT_DE_PASSE_FORT_XXXXX

# Pour utiliser un hash Argon2 au lieu du plaintext (recommandé) :
# Générer le hash :
#   python -c "from python.security.auth import hash_password; print(hash_password('VotreMotDePasse'))"
# Puis remplacer AUTH_PASSWORD par le hash $argon2id$...

# ═══════════════════════════════════════════════════════════════════════════════
# SERVEUR
# ═══════════════════════════════════════════════════════════════════════════════

# Port interne Flask (pas besoin de changer, Caddy fait le proxy)
WEB_UI_PORT=5050

# Écouter sur toutes les interfaces (OBLIGATOIRE dans Docker)
WEB_UI_HOST=0.0.0.0

# Fuseau horaire
DEFAULT_USER_TIMEZONE=Europe/Paris
DEFAULT_USER_UTC_OFFSET_MINUTES=60

# Désactiver la télémétrie
ANONYMIZED_TELEMETRY=false

# ═══════════════════════════════════════════════════════════════════════════════
# SÉCURITÉ PRODUCTION
# ═══════════════════════════════════════════════════════════════════════════════

# Active les protections production (cookies sécurisés, headers stricts)
# ⚠️  En production, forcer à true (après migration AUTH_PASSWORD en hash Argon2)
# Passer à true une fois AUTH_PASSWORD migré vers un hash Argon2 :
#   docker exec -it evidence-backend python -c \
#     "from python.security.auth import hash_password; print(hash_password('VotreMotDePasse'))"
KOREV_PRODUCTION=false

# Indique que Flask est derrière un reverse proxy (Caddy)
KOREV_BEHIND_PROXY=true

# Clé secrète Flask — OBLIGATOIRE en production pour persistance des sessions.
# Sans cette clé, les sessions sont invalidées à chaque redémarrage conteneur.
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=XXXXX_GENERER_UNE_CLE_ALEATOIRE_XXXXX

# ═══════════════════════════════════════════════════════════════════════════════
# MULTI-UTILISATEURS & DOSSIERS PARTAGÉS
# ═══════════════════════════════════════════════════════════════════════════════

# Dossier partagé racine (workspaces utilisateurs + dossier commun)
# Ce volume est monté dans Docker ET exposé via Samba aux postes Windows
EVIDENCE_SHARED_DIR=/app/shared

# Utilisateurs Samba (format: "login;motdepasse")
# IMPORTANT: synchroniser avec users.json pour les mêmes logins
# Adapter les noms et mots de passe à vos utilisateurs réels
# ⚠️  CHANGER LES MOTS DE PASSE CI-DESSOUS AVANT DEPLOIEMENT !
SMB_USER_1=marie;CHANGER_CE_MDP_1
SMB_USER_2=jean;CHANGER_CE_MDP_2
SMB_USER_3=pierre;CHANGER_CE_MDP_3
SMB_USER_4=sophie;CHANGER_CE_MDP_4
SMB_USER_5=thomas;CHANGER_CE_MDP_5
SMB_USER_6=claire;CHANGER_CE_MDP_6
SMB_USER_ADMIN=admin;CHANGER_CE_MDP_ADMIN

# Port Samba (445 par défaut, standard Windows)
SMB_PORT=445
# Bind Samba local uniquement (ne pas exposer 445 publiquement)
SMB_BIND_HOST=127.0.0.1

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER COMPOSE — RÉSEAU
# ═══════════════════════════════════════════════════════════════════════════════

# Adresse d'écoute de Caddy (0.0.0.0 = accessible depuis le LAN)
BIND_HOST=0.0.0.0

# Ports exposés par Caddy sur l'hôte
HTTP_PORT=80
HTTPS_PORT=443

# Version de l'image (tag Docker)
EVIDENCE_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════════════════
# RESSOURCES DOCKER
# ═══════════════════════════════════════════════════════════════════════════════

# Ajuster selon les ressources de votre serveur
# VPS 4 Go RAM : MEMORY_LIMIT=3G
# VPS 8 Go RAM : MEMORY_LIMIT=6G
# Serveur dédié : MEMORY_LIMIT=8G
CPU_LIMIT=4.0
MEMORY_LIMIT=4G

# ═══════════════════════════════════════════════════════════════════════════════
# CLÉS API OPTIONNELLES (enrichissement des recherches)
# ═══════════════════════════════════════════════════════════════════════════════

# Firecrawl — Web scraping avancé
# Obtenir une clé : https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=

# Brave Search — Recherche web (2000 req/mois gratuites)
# Obtenir une clé : https://brave.com/search/api/
BRAVE_API_KEY=

# Tavily — Recherche IA
# Obtenir une clé : https://tavily.com/
TAVILY_API_KEY=

# PubMed / NCBI — Recherche biomédicale
# Obtenir une clé : https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# SerpApi — Google Patents (100 req/mois gratuites)
# Obtenir une clé : https://serpapi.com/
SERPAPI_API_KEY=

# PISTE — Légifrance / Judilibre
# Obtenir un accès : https://piste.gouv.fr
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# RECHERCHE
# ═══════════════════════════════════════════════════════════════════════════════

# Fournisseur de recherche (duckduckgo par défaut si searxng non dispo)
# SEARCH_PROVIDER=duckduckgo
