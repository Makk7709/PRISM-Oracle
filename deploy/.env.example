# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                  KOREV EVIDENCE — Configuration                              ║
# ║                                                                              ║
# ║  Copier ce fichier vers .env et configurer les valeurs                       ║
# ║  ATTENTION: Ne jamais commiter .env avec des secrets !                       ║
# ║                                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════════
# VERSION & IDENTIFICATION
# ═══════════════════════════════════════════════════════════════════════════════
EVIDENCE_VERSION=1.0.0
EVIDENCE_INSTANCE_ID=dica-001
EVIDENCE_ENV=production

# ═══════════════════════════════════════════════════════════════════════════════
# RÉSEAU & PORTS
# ═══════════════════════════════════════════════════════════════════════════════
# SÉCURITÉ: Par défaut, bind uniquement sur localhost
# Pour accès LAN, changer en 0.0.0.0 (avec précaution)
BIND_HOST=127.0.0.1
BACKEND_PORT=5050
FRONTEND_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# MODE OFFLINE & SÉCURITÉ RÉSEAU
# ═══════════════════════════════════════════════════════════════════════════════
# OFFLINE_MODE=true : Aucun appel réseau externe autorisé
# OFFLINE_MODE=false : Appels autorisés uniquement vers NETWORK_ALLOWLIST
OFFLINE_MODE=true

# Domaines autorisés si OFFLINE_MODE=false (séparés par virgules)
NETWORK_ALLOWLIST=api.openai.com,api.anthropic.com,openrouter.ai,api.tavily.com

# Timeout global pour les appels réseau (ms)
NETWORK_TIMEOUT_MS=30000

# ═══════════════════════════════════════════════════════════════════════════════
# PRISM CONSENSUS
# ═══════════════════════════════════════════════════════════════════════════════
CONSENSUS_ENABLED=true
CONSENSUS_TIMEOUT_MS=10000
CONSENSUS_QUORUM_RATIO=0.67

# Arbitres (modèles LLM pour le consensus)
# Format: provider/model
CONSENSUS_ARBITER_1=openrouter/anthropic/claude-3.5-sonnet
CONSENSUS_ARBITER_2=openrouter/openai/gpt-4o
CONSENSUS_ARBITER_3=openrouter/google/gemini-pro-1.5

# Audit des décisions
CONSENSUS_AUDIT_LOG=true

# ═══════════════════════════════════════════════════════════════════════════════
# CLÉS API (SECRETS - À CONFIGURER)
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  NE JAMAIS COMMITER CES VALEURS
# Stocker dans un gestionnaire de secrets ou fichier .env local

# OpenRouter (recommandé - accès multi-modèles)
OPENROUTER_API_KEY=

# OpenAI (si accès direct)
OPENAI_API_KEY=

# Anthropic (si accès direct)
ANTHROPIC_API_KEY=

# Google AI (si accès direct)
GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# STOCKAGE & LOGS
# ═══════════════════════════════════════════════════════════════════════════════
# Chemins (dans le conteneur ou en local)
DATA_DIR=/app/data
LOGS_DIR=/app/logs
AUDIT_DIR=/app/audit

# Rotation des logs
LOG_MAX_SIZE_MB=50
LOG_MAX_FILES=10
LOG_LEVEL=INFO

# Rétention audit (jours)
AUDIT_RETENTION_DAYS=90

# ═══════════════════════════════════════════════════════════════════════════════
# RESSOURCES (Docker)
# ═══════════════════════════════════════════════════════════════════════════════
CPU_LIMIT=2.0
MEMORY_LIMIT=4G

# ═══════════════════════════════════════════════════════════════════════════════
# MCP SERVERS
# ═══════════════════════════════════════════════════════════════════════════════
# Activer/désactiver les MCPs
MCP_FIRECRAWL_ENABLED=false
MCP_TAVILY_ENABLED=false
MCP_PLAYWRIGHT_ENABLED=false
MCP_ARXIV_ENABLED=true
MCP_SEMANTICSCHOLAR_ENABLED=true

# Clés MCP spécifiques
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURES FLAGS
# ═══════════════════════════════════════════════════════════════════════════════
FEATURE_RESEARCH_PIPELINE=true
FEATURE_MEMORY_CONSOLIDATION=true
FEATURE_TASK_DECOMPOSITION=true
