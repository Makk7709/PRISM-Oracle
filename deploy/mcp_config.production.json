{
    "mcpServers": {
        "fetch": {
            "name": "Web Fetch",
            "type": "stdio",
            "command": "uvx",
            "args": ["mcp-server-fetch"],
            "description": "Récupère et analyse le contenu de pages web"
        },
        "arxiv": {
            "name": "Arxiv Papers",
            "type": "stdio",
            "command": "uvx",
            "args": ["arxiv-mcp-server"],
            "description": "Recherche et télécharge des papiers académiques depuis Arxiv"
        },
        "semanticscholar": {
            "name": "Semantic Scholar",
            "type": "stdio",
            "command": "python",
            "args": ["/app/mcp_servers/semanticscholar/server.py"],
            "description": "Recherche dans 200M+ de publications académiques"
        },
        "openalex": {
            "name": "OpenAlex Academic",
            "type": "stdio",
            "command": "node",
            "args": ["/app/mcp_servers/openalex/src/server.js"],
            "description": "Métadonnées académiques ouvertes (auteurs, institutions, citations)"
        },
        "firecrawl": {
            "name": "Firecrawl Web Scraper",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "firecrawl-mcp"],
            "env": {
                "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
            },
            "description": "Scraping web avancé et extraction de contenu structuré"
        },
        "tavily": {
            "name": "Tavily AI Search",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "tavily-mcp"],
            "env": {
                "TAVILY_API_KEY": "${TAVILY_API_KEY}"
            },
            "description": "Recherche web AI-powered avec ranking de pertinence"
        },
        "pubmed": {
            "name": "PubMed Biomedical",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "pubmed-mcp-server"],
            "env": {
                "NCBI_API_KEY": "${NCBI_API_KEY}"
            },
            "description": "Recherche dans la base de données biomédicale PubMed/NCBI"
        },
        "playwright": {
            "name": "Playwright Browser",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@playwright/mcp"],
            "description": "Automatisation de navigateur pour tests et scraping interactif"
        },
        "brave-search": {
            "name": "Brave Search",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@anthropic-ai/mcp-server-brave-search"],
            "env": {
                "BRAVE_API_KEY": "${BRAVE_API_KEY}"
            },
            "description": "Recherche web avancée via Brave Search API"
        },
        "puppeteer": {
            "name": "Puppeteer Browser",
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-puppeteer@0.6.2"],
            "description": "Automatisation de navigateur pour scraping et screenshots"
        }
    }
}
