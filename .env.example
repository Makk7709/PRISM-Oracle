# ═══════════════════════════════════════════════════════════════════════════════
#  KOREV ORACLE - Configuration
#  Copiez ce fichier vers .env et remplissez vos clés API
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# CLÉ API PRINCIPALE (REQUISE)
# ─────────────────────────────────────────────────────────────────────────────────

# OpenRouter - https://openrouter.ai/keys
# Utilisé pour tous les modèles de chat (Claude, GPT-4, etc.)
API_KEY_OPENROUTER=

# ─────────────────────────────────────────────────────────────────────────────────
# GÉNÉRATION D'IMAGE (OPTIONNEL)
# ─────────────────────────────────────────────────────────────────────────────────

# La clé OpenAI pour DALL-E 3 se configure dans l'interface Oracle :
# Paramètres → Génération d'image → Clé API OpenAI
#
# Si vous avez une clé OpenAI dédiée pour les images, vous pouvez
# aussi la mettre ici (elle sera utilisée comme fallback) :
# API_KEY_OPENAI=

# ─────────────────────────────────────────────────────────────────────────────────
# CONFIGURATION SERVEUR
# ─────────────────────────────────────────────────────────────────────────────────

# Port de l'interface web (défaut: 5050)
WEB_UI_PORT=5050

# Fuseau horaire (défaut: Europe/Paris)
DEFAULT_USER_TIMEZONE=Europe/Paris

# Désactiver la télémétrie anonymisée
ANONYMIZED_TELEMETRY=false

# ─────────────────────────────────────────────────────────────────────────────────
# MODE LEGAL-SAFE (OPTIONNEL)
# ─────────────────────────────────────────────────────────────────────────────────

# Environnement: "development" ou "production"
# - development: simulation consensus activée par défaut (pas de clés API requises)
# - production: consensus réel obligatoire (requiert des clés API pour les arbitres)
# EVIDENCE_ENV=development

# Pipeline juridique (défaut: activé)
# LEGAL_PIPELINE_ENABLED=1

# Simulation du consensus (auto-détecté selon EVIDENCE_ENV)
# En développement: activé par défaut (pas besoin de configurer les arbitres)
# En production: désactivé (consensus réel avec LLMs multiples)
# LEGAL_CONSENSUS_SIMULATION=1

# Configuration des arbitres pour le consensus réel (production uniquement)
# Format JSON: [{"provider":"openai","model":"gpt-4o"},...]
# CONSENSUS_ARBITERS=
