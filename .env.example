# ═══════════════════════════════════════════════════════════════════════════════
#  KOREV ORACLE - Configuration
#  Copiez ce fichier vers .env et remplissez vos clés API
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# CLÉS API (au moins une requise)
# ─────────────────────────────────────────────────────────────────────────────────

# OpenAI (recommandé) - https://platform.openai.com/api-keys
API_KEY_OPENAI=

# OpenRouter (alternative) - https://openrouter.ai/keys
API_KEY_OPENROUTER=

# Anthropic (optionnel) - https://console.anthropic.com/
API_KEY_ANTHROPIC=

# ─────────────────────────────────────────────────────────────────────────────────
# CONFIGURATION SERVEUR
# ─────────────────────────────────────────────────────────────────────────────────

# Port de l'interface web (défaut: 5050)
WEB_UI_PORT=5050

# Fuseau horaire (défaut: Europe/Paris)
DEFAULT_USER_TIMEZONE=Europe/Paris

# Désactiver la télémétrie anonymisée
ANONYMIZED_TELEMETRY=false

# ─────────────────────────────────────────────────────────────────────────────────
# OPTIONS AVANCÉES (optionnel)
# ─────────────────────────────────────────────────────────────────────────────────

# Modèle par défaut pour le chat
# DEFAULT_CHAT_MODEL=openai/gpt-4o

# Modèle pour les embeddings
# DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small
