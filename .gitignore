# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/

#Ignore IDE files
.cursor/
.windsurf/

# Internal infra/server reference — MUST NOT be tracked (contains infra topology)
docs/INFRA_SERVEUR_OVH.md

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/
.venv-ci311/
.ci-logs/
ci-unit-junit.xml
ci-full-junit.xml

# Handle memory directory
memory/**
!memory/**/

# Handle logs directory
logs/*

# Handle tmp and usr directory
tmp/*
usr/*

# Handle knowledge directory
knowledge/**
!knowledge/**/
# Explicitly allow the default folder in knowledge
!knowledge/default/
!knowledge/default/**

# Handle instruments directory
instruments/**
!instruments/**/
# Explicitly allow the default folder in instruments
!instruments/default/
!instruments/default/**

# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

venv/

# Legal data (local index, cache, processed files — large binaries, regenerable)
data/legal/cache/
data/legal/processed/
data/legal/reports/
data/legal/index/*.sqlite
data/legal/index/*.sqlite-shm
data/legal/index/*.sqlite-wal

# Deploy secrets / temp configs
deploy/.env.tmp
# Comptes utilisateurs production (hashes Argon2 — jamais dans le repo).
# NB: deploy/users.demo.json (comptes de démo) reste tracké volontairement.
deploy/users.json
data/users.local.json
